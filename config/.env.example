# Local Redis (default)
REDIS_URL=redis://127.0.0.1:6379

# Azure / cloud Redis (TLS):
# REDIS_URL=rediss://:<password>@<host>.redis.cache.windows.net:6380

SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# How often to poll OpenSky Network (seconds)
POLL_INTERVAL_SECS=30

# S2 cell level (9 ≈ 70 km cells, 12 ≈ 2 km)
S2_LEVEL=9

# Entity uniqueness:
# - Every write immediately removes the entity from its previous cell.
# - ENTITY_TTL_SECS is a safety-net for entities that stop reporting
#   entirely (e.g. aircraft that lands and disappears from the feed).
# - Set to ~10× your write interval — it should almost never fire.
ENTITY_TTL_SECS=300

# SQLite path for per-node metadata + position history (demo/server)
SQLITE_PATH=georedis.db

# Distributed cluster snapshot (geo-node only)
# SNAPSHOT_PATH=/data/snapshot.db
# SNAPSHOT_INTERVAL_SECS=300

RUST_LOG=info

# ── ADSB.fi demo (port 3001) ──────────────────────────────────────────────
# Drop-in OpenSky replacement with higher rate limits, no key required.
# Run: cargo run -p georedis-adsb
# ADSB_SERVER_PORT=3001

# ── AISStream.io demo (port 3002) ─────────────────────────────────────────
# Real-time WebSocket vessel tracking (~100k ships, push-based).
# Get a free API key at https://aisstream.io then set:
# AISSTREAM_API_KEY=your_key_here
# AIS_SERVER_PORT=3002
# AIS_SYNC_INTERVAL_SECS=5
