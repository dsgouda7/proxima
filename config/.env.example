# Local Redis (default)
REDIS_URL=redis://127.0.0.1:6379

# Azure / cloud Redis (TLS):
# REDIS_URL=rediss://:<password>@<host>.redis.cache.windows.net:6380

SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# How often to poll OpenSky Network (seconds)
POLL_INTERVAL_SECS=30

# S2 cell level (9 ≈ 70 km cells, 12 ≈ 2 km)
S2_LEVEL=9

# Entity uniqueness:
# - Every write immediately removes the entity from its previous cell.
# - ENTITY_TTL_SECS is a safety-net for entities that stop reporting
#   entirely (e.g. aircraft that lands and disappears from the feed).
# - Set to ~10× your write interval — it should almost never fire.
ENTITY_TTL_SECS=300

# SQLite path for per-node metadata + position history (demo/server)
SQLITE_PATH=geo-redis.db

# ── Multi-tenant Redis isolation ───────────────────────────────────────────
# Every demo app can share one Redis instance safely because each writes
# under its own key namespace (default differs per binary — see below).
# All keys become `{<namespace>}:entity:*`, `{<namespace>}:cell:*`, etc.
# Override only if you need a custom convention; the shared REDIS_URL above
# is fine to leave as-is for every app.
#   demo/server (aircraft tracker) → default "geo-redis-demo"
#   demo/weather-server (weather)  → default "geo-redis-weather"
#   demo/geo-node (cluster shard)  → default "geo-redis"
# KEY_NAMESPACE=geo-redis-demo

# Distributed cluster snapshot (geo-node only)
# SNAPSHOT_PATH=/data/snapshot.db
# SNAPSHOT_INTERVAL_SECS=300

RUST_LOG=info

# ── Weather demo (geo-redis-weather, port 3001) ─────────────────────────────
# Shares this same .env — override SERVER_PORT and KEY_NAMESPACE via process
# env vars if running both apps from one .env at the same time, e.g.:
#   $env:SERVER_PORT="3001"; cargo run --release -p geo-redis-weather
# Run: cargo run --release -p geo-redis-weather
